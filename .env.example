# finalstudy local development env
# Copy this file to .env.local and fill real values.
# Never commit .env.local.

# Gemini API key used by server API routes.
GEMINI_API_KEY=...

# Single-password app gate for the personal deployed web app.
APP_PASSWORD=change-me

# Random long secret for signing/verifying the app session cookie.
# Example generation: openssl rand -base64 32
SESSION_SECRET=change-me-to-random-long-secret

# Supabase project URL and server-only service role key.
# Service role key must never be exposed to client-side code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
